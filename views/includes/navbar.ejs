<style>
#mainNavbar {
    box-shadow: 0 1px 0 rgba(0,0,0,0.08);
    padding: 12px 0;
}

.navbar-brand {
    transition: opacity 0.2s;
}

.navbar-brand:hover {
    opacity: 0.8;
}

.search-full .border:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.12) !important;
    border-color: #cccccc !important;
}

#userMenuButton:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.12) !important;
}

.dropdown-item {
    padding: 10px 16px;
    font-size: 0.9rem;
}

.dropdown-item:hover {
    background-color: #f7f7f7;
}

.navbar-toggler:focus {
    box-shadow: none;
}

@media (min-width: 992px) {
    .navbar-brand span {
        font-size: 1.4rem;
    }
}

@media (max-width: 768px) {
    #mainNavbar {
        padding: 12px 0;
    }
    
    .navbar-brand span {
        font-size: 1.2rem;
    }
}

/* Custom scrollbar for mobile menu */
#mobileNavbar {
    max-height: 100vh;
    overflow-y: auto;
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    z-index: 1000;
}

#mobileNavbar.show {
    display: block;
}
</style>

<script>
// Close mobile menu when clicking a link
document.querySelectorAll('#mobileNavbar .nav-link').forEach(link => {
    link.addEventListener('click', () => {
        document.getElementById('mobileNavbar').classList.remove('show');
    });
});
</script>
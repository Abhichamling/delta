<% 
// Default center (Kathmandu, Nepal)
const defaultLon = 85.3240;
const defaultLat = 27.7172;
const locationLon = lon || defaultLon;
const locationLat = lat || defaultLat;
const locationName = name || 'Location';
%>

<div class="map-container mb-4">
    <div id="map-<%= id %>" class="rounded-4" style="width: 100%; height: 400px;"></div>
    
    <!-- Location Info Overlay -->
    <div class="map-overlay bg-white p-3 rounded-3 shadow-sm">
        <h6 class="fw-semibold mb-1"><i class="fa-solid fa-location-dot me-2" style="color: #FF385C;"></i><%= locationName %></h6>
        <p class="small text-muted mb-0">Coordinates: <%= locationLat %>°N, <%= locationLon %>°E</p>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Create map with OpenLayers
    const map = new ol.Map({
        target: 'map-<%= id %>',
        layers: [
            new ol.layer.Tile({
                source: new ol.source.OSM()
            })
        ],
        view: new ol.View({
            center: ol.proj.fromLonLat([<%= locationLon %>, <%= locationLat %>]),
            zoom: 13,
            minZoom: 3,
            maxZoom: 19
        })
    });

    // Create ALWAYS VISIBLE marker
    const marker = new ol.Feature({
        geometry: new ol.geom.Point(
            ol.proj.fromLonLat([<%= locationLon %>, <%= locationLat %>])
        )
    });

    // Enhanced marker style for visibility
    marker.setStyle(new ol.style.Style({
        image: new ol.style.Circle({
            radius: 12,
            fill: new ol.style.Fill({color: '#FF385C'}),
            stroke: new ol.style.Stroke({color: 'white', width: 3})
        }),
        text: new ol.style.Text({
            text: '📍',
            font: 'bold 24px Arial',
            offsetY: -18,
            fill: new ol.style.Fill({color: '#FF385C'}),
            stroke: new ol.style.Stroke({color: 'white', width: 2})
        })
    }));

    // Add marker to vector layer with high z-index
    const vectorSource = new ol.source.Vector({
        features: [marker]
    });

    const vectorLayer = new ol.layer.Vector({
        source: vectorSource,
        zIndex: 1000,
        updateWhileAnimating: true,
        updateWhileInteracting: true
    });

    map.addLayer(vectorLayer);
    
    // Force marker to always render on map movements
    map.on('moveend', function() {
        vectorLayer.changed();
        map.render();
    });
    
    map.on('zoomend', function() {
        vectorLayer.changed();
        
        // Scale marker based on zoom level
        const zoom = map.getView().getZoom();
        const scale = Math.max(0.7, Math.min(1.3, zoom / 10));
        
        marker.setStyle(new ol.style.Style({
            image: new ol.style.Circle({
                radius: 12 * scale,
                fill: new ol.style.Fill({color: '#FF385C'}),
                stroke: new ol.style.Stroke({color: 'white', width: 3})
            }),
            text: new ol.style.Text({
                text: '📍',
                font: `bold ${24 * scale}px Arial`,
                offsetY: -18 * scale,
                fill: new ol.style.Fill({color: '#FF385C'}),
                stroke: new ol.style.Stroke({color: 'white', width: 2})
            })
        }));
    });

    // Click handler for marker
    map.on('click', function(e) {
        const lonLat = ol.proj.toLonLat(e.coordinate);
        const markerLonLat = [<%= locationLon %>, <%= locationLat %>];
        const distance = Math.sqrt(
            Math.pow(lonLat[0] - markerLonLat[0], 2) + 
            Math.pow(lonLat[1] - markerLonLat[1], 2)
        );
        
        if (distance < 0.01) {
            window.location.href = '/listings?location=<%= locationName %>';
        }
    });
    
    // Pulsing effect for always visible pin
    let pulse = 0;
    setInterval(() => {
        pulse = pulse === 0 ? 1 : 0;
        const currentStyle = marker.getStyle();
        marker.setStyle(new ol.style.Style({
            image: new ol.style.Circle({
                radius: pulse === 0 ? 12 : 15,
                fill: new ol.style.Fill({color: pulse === 0 ? '#FF385C' : '#FF6B8A'}),
                stroke: new ol.style.Stroke({color: 'white', width: pulse === 0 ? 3 : 4})
            }),
            text: new ol.style.Text({
                text: '📍',
                font: `bold ${pulse === 0 ? 24 : 28}px Arial`,
                offsetY: pulse === 0 ? -18 : -22,
                fill: new ol.style.Fill({color: '#FF385C'}),
                stroke: new ol.style.Stroke({color: 'white', width: 2})
            })
        }));
    }, 1000);
});
</script>

<style>
.map-container {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.map-overlay {
    position: absolute;
    bottom: 20px;
    left: 20px;
    z-index: 10;
    max-width: 300px;
}

.ol-control button {
    background-color: #FF385C !important;
    color: white !important;
}

.ol-control button:hover {
    background-color: #E31C5F !important;
}

/* Force vector layer to always render */
.ol-layer {
    z-index: auto;
}

.ol-layer:nth-child(2) {
    z-index: 1000 !important;
}
</style>
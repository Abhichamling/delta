<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>NoticeBoard - Latest Updates</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: #f5f5f5;
        }

        .noticeboard-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px;
        }

        .noticeboard-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px 20px;
            border-radius: 16px;
            margin-bottom: 24px;
            text-align: center;
        }

        .noticeboard-header h1 {
            font-size: 28px;
            margin-bottom: 8px;
        }

        .noticeboard-header p {
            opacity: 0.95;
            font-size: 16px;
        }

        .notices-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .notice-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
        }

        .notice-card:active {
            transform: scale(0.98);
        }

        .notice-image-wrapper {
            position: relative;
            width: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            overflow: hidden;
            min-height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .notice-image {
            width: 100%;
            height: 250px;
            object-fit: cover;
            display: block;
        }

        .image-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 250px;
            color: white;
            text-align: center;
        }

        .image-placeholder i {
            font-size: 64px;
            margin-bottom: 12px;
            opacity: 0.8;
        }

        .image-placeholder p {
            font-size: 14px;
            opacity: 0.9;
        }

        .notice-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            backdrop-filter: blur(4px);
        }

        .notice-content {
            padding: 20px;
        }

        .notice-title {
            font-size: 20px;
            font-weight: 700;
            color: #333;
            margin-bottom: 12px;
            line-height: 1.3;
        }

        .notice-description {
            font-size: 15px;
            line-height: 1.5;
            color: #666;
            margin-bottom: 16px;
        }

        .notice-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 12px;
            border-top: 1px solid #eee;
            font-size: 13px;
            color: #999;
        }

        .notice-author {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .view-details-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 12px;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            margin-top: 16px;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }

        .view-details-btn:active {
            background: #5a67d8;
            transform: scale(0.98);
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 16px;
        }

        .empty-state i {
            font-size: 64px;
            color: #ccc;
            margin-bottom: 16px;
        }

        .loading-spinner {
            text-align: center;
            padding: 60px 20px;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid #e0e0e0;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 16px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @media (min-width: 768px) {
            .noticeboard-container {
                padding: 24px;
            }
            
            .notices-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 24px;
            }
            
            .noticeboard-header h1 {
                font-size: 36px;
            }
        }

        @media (min-width: 1024px) {
            .notices-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        button, a, .notice-card {
            touch-action: manipulation;
        }
    </style>
</head>
<body>
    <%- include('../includes/navbar') %>
    
    <div class="noticeboard-container">
        <div class="noticeboard-header">
            <h1><i class="fas fa-bullhorn"></i> 📢 NoticeBoard</h1>
            <p>Stay updated with latest announcements and offers</p>
        </div>

        <div id="noticesContainer">
            <div class="loading-spinner">
                <div class="spinner"></div>
                <p>Loading notices...</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        class NoticeBoard {
            constructor() {
                this.notices = [];
                this.init();
            }

            async init() {
                await this.fetchNotices();
                this.setupMobileTouch();
            }

            async fetchNotices() {
                try {
                    const response = await fetch('/api/notices');
                    const data = await response.json();
                    
                    if (data.success && data.notices && data.notices.length > 0) {
                        this.notices = data.notices;
                        this.renderNotices();
                    } else {
                        this.showEmptyState();
                    }
                } catch (error) {
                    console.error('Error fetching notices:', error);
                    this.showEmptyState();
                }
            }

            getImageUrl(notice) {
                // Check all possible image fields
                if (notice.imageFile && notice.imageFile !== '') {
                    return notice.imageFile;
                }
                if (notice.imageUrl && notice.imageUrl !== '') {
                    return notice.imageUrl;
                }
                if (notice.image && notice.image !== '') {
                    return notice.image;
                }
                return null;
            }

            renderNotices() {
                const container = document.getElementById('noticesContainer');
                
                if (this.notices.length === 0) {
                    this.showEmptyState();
                    return;
                }

                let html = '<div class="notices-grid">';
                
                this.notices.forEach(notice => {
                    const imageUrl = this.getImageUrl(notice);
                    const displayText = notice.content || notice.description || '';
                    const title = notice.title || 'Untitled Notice';
                    const author = notice.author || 'Admin';
                    const date = notice.createdAt ? new Date(notice.createdAt).toLocaleDateString() : 'Recent';
                    
                    html += `
                        <div class="notice-card" data-notice-id="${notice._id}" onclick="viewNotice('${notice._id}')">
                            <div class="notice-image-wrapper">
                                ${imageUrl ? `
                                    <img src="${imageUrl}" 
                                         alt="${this.escapeHtml(title)}" 
                                         class="notice-image"
                                         loading="lazy"
                                         onerror="this.onerror=null; this.parentElement.innerHTML=this.getPlaceholder('${this.escapeHtml(title)}')">
                                ` : `
                                    <div class="image-placeholder">
                                        <i class="fas fa-image"></i>
                                        <p>No Image Available</p>
                                    </div>
                                `}
                                <span class="notice-badge">
                                    <i class="fas fa-calendar-alt"></i> ${date}
                                </span>
                            </div>
                            <div class="notice-content">
                                <h3 class="notice-title">${this.escapeHtml(title)}</h3>
                                <p class="notice-description">${this.truncate(this.escapeHtml(displayText), 120)}</p>
                                
                                <div class="notice-meta">
                                    <div class="notice-author">
                                        <i class="fas fa-user-circle"></i>
                                        <span>${this.escapeHtml(author)}</span>
                                    </div>
                                </div>
                                
                                <button class="view-details-btn" onclick="event.stopPropagation(); viewNotice('${notice._id}')">
                                    <i class="fas fa-eye"></i> Read More
                                    <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                    `;
                });
                
                html += '</div>';
                container.innerHTML = html;
            }

            getPlaceholder(title) {
                return `<div class="image-placeholder">
                            <i class="fas fa-newspaper"></i>
                            <p>${this.escapeHtml(title)}</p>
                        </div>`;
            }

            showEmptyState() {
                const container = document.getElementById('noticesContainer');
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-bullhorn"></i>
                        <h3>No Notices Available</h3>
                        <p class="text-muted">Check back later for updates and announcements!</p>
                        <a href="/listings" class="btn btn-primary mt-3">
                            <i class="fas fa-home"></i> Browse Listings
                        </a>
                    </div>
                `;
            }

            setupMobileTouch() {
                const cards = document.querySelectorAll('.notice-card');
                cards.forEach(card => {
                    card.addEventListener('touchstart', function() {
                        this.style.transform = 'scale(0.98)';
                    });
                    card.addEventListener('touchend', function() {
                        this.style.transform = 'scale(1)';
                        setTimeout(() => {
                            this.style.transform = '';
                        }, 100);
                    });
                });
            }

            escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            truncate(text, length) {
                if (!text) return '';
                if (text.length <= length) return text;
                return text.substring(0, length) + '...';
            }
        }

        function viewNotice(noticeId) {
            window.location.href = `/notices/${noticeId}`;
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                new NoticeBoard();
            });
        } else {
            new NoticeBoard();
        }

        window.addEventListener('orientationchange', function() {
            setTimeout(() => {
                window.dispatchEvent(new Event('resize'));
            }, 100);
        });
    </script>
</body>
</html>
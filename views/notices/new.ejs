<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Notice</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
        .form-container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
        .card { border-radius: 20px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.1); }
        .card-header { background: linear-gradient(135deg, #FF385C 0%, #E31C5F 100%); padding: 30px; }
        .image-preview { 
            max-width: 100%; 
            max-height: 200px; 
            border-radius: 10px; 
            margin-top: 15px;
            border: 2px solid #ddd;
        }
        .upload-area {
            border: 2px dashed #ddd;
            border-radius: 10px;
            padding: 30px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: #f8f9fa;
        }
        .upload-area:hover {
            border-color: #FF385C;
            background: #fff5f7;
        }
        .image-tab {
            cursor: pointer;
            padding: 10px 20px;
            border: none;
            background: none;
            font-weight: 500;
            transition: all 0.3s;
        }
        .image-tab.active {
            color: #FF385C;
            border-bottom: 2px solid #FF385C;
        }
        .image-section {
            display: none;
        }
        .image-section.active {
            display: block;
        }
    </style>
</head>
<body>
    <div class="form-container">
        <div class="card shadow">
            <div class="card-header text-white">
                <div class="text-center">
                    <i class="fas fa-bullhorn" style="font-size: 3rem; margin-bottom: 15px;"></i>
                    <h2 class="mb-0">Create New Notice</h2>
                    <p class="mb-0 mt-2">Share important announcements with your community</p>
                </div>
            </div>
            <div class="card-body p-4">
                <form action="/notices" method="POST" enctype="multipart/form-data" id="noticeForm">
                    <!-- Title -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="fas fa-heading text-danger"></i> Notice Title *
                        </label>
                        <input type="text" name="title" class="form-control form-control-lg" 
                               placeholder="Enter notice title" required>
                    </div>
                    
                    <!-- Author -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="fas fa-user text-danger"></i> Author
                        </label>
                        <input type="text" name="author" class="form-control" value="Admin">
                    </div>
                    
                    <!-- Image Selection Tabs -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="fas fa-image text-danger"></i> Notice Image (Optional)
                        </label>
                        
                        <div class="border-bottom mb-3">
                            <button type="button" class="image-tab active" onclick="switchTab('url')">
                                <i class="fas fa-link"></i> Image URL
                            </button>
                            <button type="button" class="image-tab" onclick="switchTab('upload')">
                                <i class="fas fa-upload"></i> Upload from Device
                            </button>
                        </div>
                        
                        <!-- Image URL Section -->
                        <div id="urlSection" class="image-section active">
                            <input type="url" name="imageUrl" class="form-control" 
                                   placeholder="https://images.unsplash.com/photo-...">
                            <small class="text-muted">Paste an image URL from the web</small>
                            <div id="urlPreview" class="mt-2"></div>
                        </div>
                        
                        <!-- Upload Section -->
                        <div id="uploadSection" class="image-section">
                            <div class="upload-area" onclick="document.getElementById('imageFile').click()">
                                <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-2"></i>
                                <p class="mb-1">Click to upload an image</p>
                                <small class="text-muted">Supports JPG, PNG, GIF (Max 5MB)</small>
                                <input type="file" name="image" id="imageFile" accept="image/*" style="display: none;" onchange="previewUpload(this)">
                            </div>
                            <img id="uploadPreview" class="image-preview" style="display: none;">
                        </div>
                    </div>
                    
                    <!-- Content -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="fas fa-align-left text-danger"></i> Notice Content 
                        </label>
                        <textarea name="content" rows="6" class="form-control" 
                                  placeholder="Write your notice content here..." required></textarea>
                    </div>
                    
                    <!-- Display Dates -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-calendar-alt text-danger"></i> Display From
                                </label>
                                <input type="datetime-local" name="displayFrom" class="form-control">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-calendar-times text-danger"></i> Display Until
                                </label>
                                <input type="datetime-local" name="displayUntil" class="form-control">
                                <small class="text-muted">Leave empty for no expiry</small>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Active Status -->
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" name="isActive" class="form-check-input" id="isActive" checked>
                            <label class="form-check-label fw-bold" for="isActive">
                                <i class="fas fa-check-circle text-success"></i> Active Notice
                            </label>
                            <div class="text-muted small">When active, this notice will be shown ONCE to each user</div>
                        </div>
                    </div>
                    
                    <!-- Buttons -->
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save"></i> Publish Notice
                        </button>
                        <a href="/notices" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <script>
        function switchTab(tab) {
            const urlSection = document.getElementById('urlSection');
            const uploadSection = document.getElementById('uploadSection');
            const tabs = document.querySelectorAll('.image-tab');
            
            tabs.forEach(t => t.classList.remove('active'));
            
            if (tab === 'url') {
                urlSection.classList.add('active');
                uploadSection.classList.remove('active');
                tabs[0].classList.add('active');
            } else {
                urlSection.classList.remove('active');
                uploadSection.classList.add('active');
                tabs[1].classList.add('active');
            }
        }
        
        function previewUpload(input) {
            const preview = document.getElementById('uploadPreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        // Preview URL image
        document.querySelector('input[name="imageUrl"]').addEventListener('input', function() {
            const url = this.value;
            const preview = document.getElementById('urlPreview');
            if (url) {
                preview.innerHTML = `<img src="${url}" class="image-preview" onerror="this.style.display='none'">`;
            } else {
                preview.innerHTML = '';
            }
        });
    </script>
</body>
</html>
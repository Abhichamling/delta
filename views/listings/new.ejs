<% layout("/layouts/boilerplate") %>

<%- include('../includes/navbar') %>
<%- include('../includes/flash') %>

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-9">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="card-body">
                <h2 class="fw-light mb-4 text-center">
                    <i class="fas fa-plus-circle me-2"></i>
                    Create New Listing
                </h2>
                
                <form action="/listings" method="POST" enctype="multipart/form-data" id="listingForm">
                    <!-- Basic Info Section -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Title <span class="text-danger"></span></label>
                            <input type="text" name="listing[title]" class="form-control rounded-3" required 
                                   placeholder="e.g., Places Villa">
                        </div>
                    </div>
                    
                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description <span class="text-danger"></span></label>
                        <textarea name="listing[description]" class="form-control rounded-3" rows="3" required
                                  placeholder="Describe your place..."></textarea>
                    </div>
                    
                    <!-- Location Row -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Location <span class="text-danger"></span></label>
                            <input type="text" name="listing[location]" class="form-control rounded-3" required 
                                   placeholder="e.g., Kathmandu">
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Country <span class="text-danger"></span></label>
                            <input type="text" name="listing[country]" class="form-control rounded-3" required 
                                   placeholder="e.g., Nepal">
                        </div>
                    </div>
                    
                    <!-- Price Field -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Price (₹ / $) <span class="text-danger"></span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">$</span>
                            <input type="number" name="listing[price]" class="form-control rounded-3" required min="0" step="0.01" placeholder="e.g., 5000">
                        </div>
                    </div>
                    
                    <!-- Google Maps Link Field -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-map-marker-alt me-2"></i>Google Maps Location Link
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-link"></i>
                            </span>
                            <input type="url" name="listing[googleMapsUrl]" class="form-control rounded-3" 
                                   placeholder="https://maps.app.goo.gl/4aYVrEkysAdVHVpy8" 
                                   value="">
                        </div>
                        <small class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Paste a Google Maps share link for your location
                        </small>
                    </div>
                    
                    <!-- Categories - Multiple Select (Up to 10) -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Categories <span class="text-danger"></span> <span class="text-muted small">(Select up to 10)</span></label>
                        <div class="category-grid">
                            
                            <% const categories = [
                                'All', 'Trending', 'Mountain', 'Himalayan', 'Adventure', 'Trekking',
                                'Wildlife', 'Culture', 'Heritage', 'Yoga', 'Agriculture', 'Education',
                                'Food', 'Kitchen', 'Camping', 'Beach', 'Lake', 'Desert', 'Forest',
                                'River', 'City', 'Village', 'Farm', 'Garden', 'Spa', 'Meditation',
                                'Photography', 'Art', 'Music', 'Dance', 'Workshop', 'Cooking',
                                'Wine', 'Coffee', 'Tea'
                            ]; %>
                            
                            <% categories.forEach(category => { %>
                                <label class="category-checkbox">
                                    <input type="checkbox" name="listing[categories][]" value="<%= category %>" class="category-input">
                                    <span class="category-item"><%= category %></span>
                                </label>
                            <% }); %>
                        </div>
                        <div id="category-error" class="text-danger small mt-2" style="display: none;">You can only select up to 10 categories</div>
                        <div id="category-count" class="text-muted small mt-1">Selected: 0 / 10</div>
                    </div>
                    
                    <!-- ========== IMAGES SECTION - SIMPLE VERSION (NO LINKS) ========== -->
                    <div class="mb-5 p-4 border rounded-5 bg-light">
                        <h5 class="fw-semibold mb-3">Add Photos <span class="text-muted small fw-normal">(Up to 30 images, Max 5MB each)</span></h5>
                        
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Upload Images</label>
                            <input type="file" name="listing[images]" class="form-control rounded-3" 
                                   multiple accept="image/*" id="imageUpload">
                            <small class="text-muted">You can select up to 30 images at once (Max 5MB per image)</small>
                            <div id="fileSizeWarning" class="text-warning small mt-1" style="display: none;">
                                <i class="fas fa-exclamation-triangle"></i> Some files are too large. Maximum size is 5MB per image.
                            </div>
                            <div id="compressionStatus" class="text-info small mt-1" style="display: none;">
                                <i class="fas fa-spinner fa-spin"></i> Compressing large images...
                            </div>
                        </div>
                        
                        <!-- Preview Selected Files -->
                        <div id="uploadPreview" class="row g-2 mt-3"></div>
                        <div id="uploadCount" class="text-muted small mt-2 text-center"></div>
                        
                        <!-- Image Counter -->
                        <div class="mt-3 d-flex justify-content-between align-items-center">
                            <span id="imageCount" class="badge bg-secondary">0 / 30 images selected</span>
                            <small class="text-muted">*At least 1 image required</small>
                        </div>
                    </div>
                    
                    <!-- Optional Fields -->
                    <div class="mb-3">
                        <button class="btn btn-outline-secondary w-100 text-start" type="button" data-bs-toggle="collapse" data-bs-target="#moreOptions">
                            <i class="fas fa-plus me-2"></i> Additional Details (optional)
                        </button>
                    </div>
                    
                    <div class="collapse" id="moreOptions">
                        <div class="card card-body border-0 bg-light p-3 mb-3 rounded-4">
                            <!-- Amenities -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Amenities (comma separated)</label>
                                <input type="text" name="listing[amenities]" class="form-control rounded-3" 
                                       placeholder="e.g., WiFi, Pool, Kitchen, Parking, AC">
                            </div>
                            
                            <!-- Experiences -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Experiences (comma separated)</label>
                                <input type="text" name="listing[experiences]" class="form-control rounded-3" 
                                       placeholder="e.g., Trekking, Yoga, Cooking, Photography">
                            </div>
                            
                            <!-- Season and Duration -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Best Season</label>
                                    <input type="text" name="listing[bestSeason]" class="form-control rounded-3" 
                                           placeholder="e.g., October to March">
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Duration</label>
                                    <input type="text" name="listing[duration]" class="form-control rounded-3" 
                                           placeholder="e.g., 3 Days / 2 Nights">
                                </div>
                            </div>
                            
                            <!-- Difficulty -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Difficulty</label>
                                <select name="listing[difficulty]" class="form-select rounded-3">
                                    <option value="Easy">Easy</option>
                                    <option value="Moderate" selected>Moderate</option>
                                    <option value="Challenging">Challenging</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <hr class="my-4">
                    
                    <!-- Submit Buttons -->
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/listings" class="btn btn-outline-secondary rounded-3 px-4 py-2">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary rounded-3 px-5 py-2">
                            <i class="fas fa-check-circle me-2"></i> Create Listing
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../includes/footer') %>

<style>
.category-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
    max-height: 200px;
    overflow-y: auto;
    padding: 10px;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    background-color: #f8f9fa;
}

.category-checkbox {
    display: inline-block;
    cursor: pointer;
}

.category-checkbox input {
    display: none;
}

.category-item {
    display: inline-block;
    padding: 6px 12px;
    background-color: white;
    border: 1px solid #dee2e6;
    border-radius: 20px;
    font-size: 0.9rem;
    transition: all 0.2s;
}

.category-checkbox input:checked + .category-item {
    background-color: #000000;
    color: white;
    border-color: #000000;
}

.preview-image {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #dee2e6;
}

.preview-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.remove-btn {
    position: absolute;
    top: 5px;
    right: 5px;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #dc3545;
    z-index: 10;
}

.remove-btn:hover {
    background: white;
    transform: scale(1.1);
}

.file-size-badge {
    font-size: 0.7rem;
    background: rgba(0,0,0,0.7) !important;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ========== CONSTANTS ==========
    const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB per file
    const MAX_IMAGE_DIMENSION = 1920;
    
    // ========== CATEGORY SELECTION - UP TO 10 ==========
    const categoryInputs = document.querySelectorAll('.category-input');
    const categoryError = document.getElementById('category-error');
    const categoryCount = document.getElementById('category-count');
    
    function updateCategoryCount() {
        const checkedCount = document.querySelectorAll('.category-input:checked').length;
        categoryCount.textContent = `Selected: ${checkedCount} / 10`;
        
        if (checkedCount >= 10) {
            categoryCount.style.color = '#dc3545';
            categoryInputs.forEach(input => {
                if (!input.checked) {
                    input.disabled = true;
                }
            });
        } else {
            categoryCount.style.color = '#6c757d';
            categoryInputs.forEach(input => {
                input.disabled = false;
            });
        }
    }
    
    categoryInputs.forEach(input => {
        input.addEventListener('change', function() {
            const checkedCount = document.querySelectorAll('.category-input:checked').length;
            
            if (checkedCount > 10) {
                this.checked = false;
                categoryError.style.display = 'block';
            } else {
                categoryError.style.display = 'none';
            }
            
            updateCategoryCount();
        });
    });
    
    updateCategoryCount();
    
    // ========== IMAGE COMPRESSION FUNCTION ==========
    async function compressImage(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = (event) => {
                const img = new Image();
                img.src = event.target.result;
                img.onload = () => {
                    let width = img.width;
                    let height = img.height;
                    
                    if (width > height) {
                        if (width > MAX_IMAGE_DIMENSION) {
                            height = Math.round(height * MAX_IMAGE_DIMENSION / width);
                            width = MAX_IMAGE_DIMENSION;
                        }
                    } else {
                        if (height > MAX_IMAGE_DIMENSION) {
                            width = Math.round(width * MAX_IMAGE_DIMENSION / height);
                            height = MAX_IMAGE_DIMENSION;
                        }
                    }
                    
                    const canvas = document.createElement('canvas');
                    canvas.width = width;
                    canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    
                    canvas.toBlob((blob) => {
                        const compressedFile = new File([blob], file.name, {
                            type: 'image/jpeg',
                            lastModified: Date.now()
                        });
                        resolve(compressedFile);
                    }, 'image/jpeg', 0.8);
                };
                img.onerror = reject;
            };
            reader.onerror = reject;
        });
    }
    
    // ========== IMAGE UPLOAD HANDLING ==========
    const imageUpload = document.getElementById('imageUpload');
    const uploadPreview = document.getElementById('uploadPreview');
    const imageCount = document.getElementById('imageCount');
    const uploadCount = document.getElementById('uploadCount');
    const fileSizeWarning = document.getElementById('fileSizeWarning');
    const compressionStatus = document.getElementById('compressionStatus');
    let selectedFiles = [];
    let isCompressing = false;
    
    if (imageUpload) {
        imageUpload.addEventListener('change', async function(e) {
            if (isCompressing) {
                alert('Please wait for current compression to finish');
                return;
            }
            
            const files = Array.from(e.target.files);
            
            if (files.length > 30) {
                alert('You can only upload up to 30 images');
                imageUpload.value = '';
                return;
            }
            
            const oversizedFiles = files.filter(file => file.size > MAX_FILE_SIZE);
            if (oversizedFiles.length > 0) {
                fileSizeWarning.style.display = 'block';
                fileSizeWarning.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${oversizedFiles.length} file(s) are too large. Compressing...`;
                
                compressionStatus.style.display = 'block';
                compressionStatus.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Compressing ${oversizedFiles.length} large image(s)...`;
                
                isCompressing = true;
                
                try {
                    const compressedFiles = await Promise.all(files.map(async file => {
                        if (file.size > MAX_FILE_SIZE) {
                            return await compressImage(file);
                        }
                        return file;
                    }));
                    
                    const dt = new DataTransfer();
                    compressedFiles.forEach(file => dt.items.add(file));
                    imageUpload.files = dt.files;
                    
                    selectedFiles = compressedFiles;
                    
                    compressionStatus.style.display = 'none';
                    fileSizeWarning.style.display = 'none';
                    
                    const successMsg = document.createElement('div');
                    successMsg.className = 'alert alert-success alert-dismissible fade show mt-2';
                    successMsg.innerHTML = `
                        <i class="fas fa-check-circle"></i> ${oversizedFiles.length} large image(s) compressed successfully!
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    `;
                    uploadPreview.parentNode.insertBefore(successMsg, uploadPreview);
                    
                    setTimeout(() => {
                        if (successMsg.parentNode) {
                            successMsg.remove();
                        }
                    }, 3000);
                    
                } catch (error) {
                    console.error('Compression error:', error);
                    alert('Error compressing images. Please try again with smaller files.');
                    selectedFiles = files;
                } finally {
                    isCompressing = false;
                }
            } else {
                fileSizeWarning.style.display = 'none';
                selectedFiles = files;
            }
            
            updateImageCount(selectedFiles.length);
            displayUploadPreviews(selectedFiles);
        });
    }
    
    function displayUploadPreviews(files) {
        if (!uploadPreview) return;
        
        uploadPreview.innerHTML = '';
        
        if (files.length === 0) {
            uploadCount.textContent = '';
            return;
        }
        
        files.forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const col = document.createElement('div');
                col.className = 'col-4 col-md-3 col-lg-2 mb-2';
                col.innerHTML = `
                    <div class="preview-image">
                        <img src="${e.target.result}" alt="Preview ${index + 1}" style="width: 100%; height: 100%; object-fit: cover;">
                        <button type="button" class="remove-btn" onclick="removeUploadImage(${index})">
                            <i class="fas fa-times"></i>
                        </button>
                        <span class="badge bg-secondary position-absolute bottom-0 end-0 m-1 file-size-badge">${(file.size / 1024).toFixed(0)}KB</span>
                    </div>
                `;
                uploadPreview.appendChild(col);
            };
            reader.readAsDataURL(file);
        });
        
        uploadCount.textContent = `${files.length} image(s) selected (Total: ${(files.reduce((acc, f) => acc + f.size, 0) / (1024 * 1024)).toFixed(2)}MB)`;
    }
    
    window.updateImageCount = function(count) {
        if (imageCount) {
            imageCount.textContent = `${count} / 30 images selected`;
            if (count === 0) {
                imageCount.className = 'badge bg-danger';
            } else if (count > 0 && count < 30) {
                imageCount.className = 'badge bg-warning text-dark';
            } else {
                imageCount.className = 'badge bg-success';
            }
        }
    };
    
    window.removeUploadImage = function(index) {
        selectedFiles.splice(index, 1);
        
        const dt = new DataTransfer();
        selectedFiles.forEach(file => dt.items.add(file));
        imageUpload.files = dt.files;
        
        displayUploadPreviews(selectedFiles);
        updateImageCount(selectedFiles.length);
    };
    
    const form = document.getElementById('listingForm');
    
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const checkedCategories = document.querySelectorAll('.category-input:checked').length;
        if (checkedCategories === 0) {
            alert('Please select at least 1 category');
            return;
        }
        
        if (selectedFiles.length === 0) {
            alert('Please select at least 1 image to upload');
            return;
        }
        
        const oversizedFiles = selectedFiles.filter(file => file.size > MAX_FILE_SIZE);
        if (oversizedFiles.length > 0) {
            const shouldCompress = confirm(`${oversizedFiles.length} image(s) are still over 5MB. Would you like to compress them now?`);
            if (shouldCompress) {
                compressionStatus.style.display = 'block';
                compressionStatus.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Compressing large images...`;
                
                try {
                    const compressedFiles = await Promise.all(selectedFiles.map(async file => {
                        if (file.size > MAX_FILE_SIZE) {
                            return await compressImage(file);
                        }
                        return file;
                    }));
                    
                    const dt = new DataTransfer();
                    compressedFiles.forEach(file => dt.items.add(file));
                    imageUpload.files = dt.files;
                    selectedFiles = compressedFiles;
                    
                    compressionStatus.style.display = 'none';
                    displayUploadPreviews(selectedFiles);
                } catch (error) {
                    console.error('Compression error:', error);
                    alert('Error compressing images. Please try again or choose smaller files.');
                    return;
                }
            } else {
                return;
            }
        }
        
        const amenities = document.querySelector('input[name="listing[amenities]"]');
        const experiences = document.querySelector('input[name="listing[experiences]"]');
        
        document.querySelectorAll('input[name^="listing[amenities]"]').forEach(el => {
            if (el.name !== 'listing[amenities]') el.remove();
        });
        document.querySelectorAll('input[name^="listing[experiences]"]').forEach(el => {
            if (el.name !== 'listing[experiences]') el.remove();
        });
        
        if (amenities && amenities.value) {
            const items = amenities.value.split(',').map(item => item.trim()).filter(item => item !== '');
            items.forEach((item, index) => {
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = `listing[amenities][${index}]`;
                hidden.value = item;
                form.appendChild(hidden);
            });
        }
        
        if (experiences && experiences.value) {
            const items = experiences.value.split(',').map(item => item.trim()).filter(item => item !== '');
            items.forEach((item, index) => {
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = `listing[experiences][${index}]`;
                hidden.value = item;
                form.appendChild(hidden);
            });
        }
        
        form.submit();
    });
});
</script>
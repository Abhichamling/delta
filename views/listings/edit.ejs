<% layout("/layouts/boilerplate") %>
<%- include('../includes/navbar') %>
<%- include('../includes/flash') %>

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-9">
            <div class="card shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="mb-4">Edit this Listing</h3>
                    
                    <form action="/listings/<%= listing._id %>?_method=PUT" method="post" enctype="multipart/form-data" id="editListingForm">
                        
                        <!-- Title -->
                        <div class="mb-3">
                            <label for="title" class="form-label fw-semibold">Title <span class="text-danger"></span></label>
                            <input type="text" name="listing[title]" class="form-control rounded-3" id="title"
                                placeholder="Enter title" required value="<%= listing.title %>">
                        </div>
                        
                        <!-- Description -->
                        <div class="mb-3">
                            <label for="description" class="form-label fw-semibold">Description <span class="text-danger"></span></label>
                            <textarea name="listing[description]" class="form-control rounded-3" id="description" cols="30"
                                rows="5" placeholder="Enter description" required><%= listing.description %></textarea>
                        </div>
                        
                        <!-- Country -->
                        <div class="mb-3">
                            <label for="country" class="form-label fw-semibold">Country <span class="text-danger">*</span></label>
                            <input type="text" name="listing[country]" class="form-control rounded-3" id="country"
                                placeholder="Enter country" required value="<%= listing.country %>">
                        </div>
                        
                        <!-- Price and Location Row -->
                        <div class="row">
                            <div class="mb-3 col-md-4">
                                <label for="price" class="form-label fw-semibold">Price (₹ / $) <span class="text-danger"></span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">₹/$</span>
                                    <input type="number" placeholder="Enter price" class="form-control rounded-3"
                                        name="listing[price]" id="price" required value="<%= listing.price %>" min="0" step="0.01">
                                </div>
                                <small class="text-muted">Enter price in your local currency</small>
                            </div>
                            <div class="mb-3 col-md-8">
                                <label for="location" class="form-label fw-semibold">Location <span class="text-danger"></span></label>
                                <input type="text" name="listing[location]" class="form-control rounded-3" id="location"
                                    placeholder="Enter location" required value="<%= listing.location %>">
                            </div>
                        </div>

                        <!-- Google Maps Link Field - CLEANED UP -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="fa-regular fa-map-location-dot me-2" style="color: #8B5A2B;"></i>
                                Google Maps Location Link
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fa-regular fa-link" style="color: #8B5A2B;"></i>
                                </span>
                                <input type="url" name="listing[googleMapsUrl]" class="form-control rounded-3" 
                                       placeholder="https://maps.app.goo.gl/4aYVrEkysAdVHVpy8" 
                                       value="<%= listing.googleMapsUrl || '' %>">
                            </div>
                            <small class="text-muted">
                                <i class="fa-regular fa-circle-info me-1"></i>
                                Paste a Google Maps share link to show your location
                            </small>
                        </div>
                        
                        <!-- Categories - Multiple Select (Up to 10) -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Categories <span class="text-danger"></span> <span class="text-muted small">(Select up to 10)</span></label>
                            <div class="category-grid">
                                
                                <% const categories = [
                                    'All', 'Trending', 'Mountain', 'Himalayan', 'Adventure', 'Trekking',
                                    'Wildlife', 'Culture', 'Heritage', 'Yoga', 'Agriculture', 'Education',
                                    'Food', 'Kitchen', 'Camping', 'Beach', 'Lake', 'Desert', 'Forest',
                                    'River', 'City', 'Village', 'Farm', 'Garden', 'Spa', 'Meditation',
                                    'Photography', 'Art', 'Music', 'Dance', 'Workshop', 'Cooking',
                                    'Wine', 'Coffee', 'Tea'
                                ]; %>
                                
                                <% categories.forEach(category => { %>
                                    <label class="category-checkbox">
                                        <input type="checkbox" name="listing[categories][]" value="<%= category %>" class="category-input" 
                                               <%= listing.categories && listing.categories.includes(category) ? 'checked' : '' %>>
                                        <span class="category-item"><%= category %></span>
                                    </label>
                                <% }); %>
                            </div>
                            <div id="category-error" class="text-danger small mt-2" style="display: none;">You can only select up to 10 categories</div>
                            <div id="category-count" class="text-muted small mt-1">Selected: <span id="selected-count"><%= listing.categories ? listing.categories.length : 0 %></span> / 10</div>
                        </div>
                        
                        <!-- Current Images Display -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Current Images</label>
                            <div class="row">
                                <% if(listing.images && listing.images.length > 0) { %>
                                    <% listing.images.forEach((image, index) => { %>
                                        <div class="col-4 col-md-3 col-lg-2 mb-2">
                                            <div class="current-image position-relative">
                                                <img src="<%= image.url %>" alt="Listing image <%= index + 1 %>" 
                                                     class="img-fluid rounded-3">
                                                <div class="mt-1 text-center">
                                                    <small class="text-muted">Image <%= index + 1 %></small>
                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="col-12">
                                        <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470" 
                                             alt="Default image" class="img-fluid rounded-3 default-image">
                                    </div>
                                <% } %>
                            </div>
                            <p class="text-muted small mt-2">Current images (will be replaced if you upload new ones)</p>
                        </div>
                        
                        <!-- Upload New Images -->
                        <div class="mb-5 photo-section">
                            <h5 class="fw-semibold mb-3">Add New Photos <span class="text-muted small fw-normal">(Up to 30 images, Max 5MB each)</span></h5>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Upload New Images</label>
                                <input type="file" name="listing[images]" class="form-control rounded-3" 
                                       multiple accept="image/*" id="imageUpload">
                                <small class="text-muted">You can select up to 30 images at once. Leave empty to keep current images.</small>
                                <div id="fileSizeWarning" class="file-size-warning" style="display: none;">
                                    <i class="fas fa-exclamation-triangle"></i> Some files are too large. Maximum size is 5MB per image.
                                </div>
                                <div id="compressionStatus" class="compressing-message" style="display: none;">
                                    <i class="fas fa-spinner fa-spin"></i> Compressing large images...
                                </div>
                            </div>
                            
                            <!-- Preview New Files -->
                            <div id="uploadPreview" class="row g-2 mt-3"></div>
                            <div id="uploadCount" class="text-muted small mt-2 text-center"></div>
                            
                            <!-- Image Counter -->
                            <div class="mt-3">
                                <span id="imageCount" class="badge bg-secondary">0 / 30 new images selected</span>
                            </div>
                        </div>
                        
                        <!-- Amenities and Experiences -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="amenities" class="form-label fw-semibold">Amenities (comma separated)</label>
                                <input type="text" class="form-control rounded-3" id="amenities" name="listing[amenities]" 
                                       value="<%= listing.amenities ? listing.amenities.join(', ') : '' %>"
                                       placeholder="e.g., WiFi, Pool, Kitchen">
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label for="experiences" class="form-label fw-semibold">Experiences (comma separated)</label>
                                <input type="text" class="form-control rounded-3" id="experiences" name="listing[experiences]" 
                                       value="<%= listing.experiences ? listing.experiences.join(', ') : '' %>"
                                       placeholder="e.g., Trekking, Yoga, Cooking">
                            </div>
                        </div>
                        
                        <!-- Best Season and Duration -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="bestSeason" class="form-label fw-semibold">Best Season</label>
                                <input type="text" class="form-control rounded-3" id="bestSeason" name="listing[bestSeason]" 
                                       value="<%= listing.bestSeason || '' %>"
                                       placeholder="e.g., October to March">
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label for="duration" class="form-label fw-semibold">Duration</label>
                                <input type="text" class="form-control rounded-3" id="duration" name="listing[duration]" 
                                       value="<%= listing.duration || '' %>"
                                       placeholder="e.g., 3 Days / 6 Days">
                            </div>
                        </div>
                        
                        <!-- Difficulty -->
                        <div class="mb-3">
                            <label for="difficulty" class="form-label fw-semibold">Difficulty</label>
                            <select class="form-select rounded-3" id="difficulty" name="listing[difficulty]">
                                <option value="Easy" <%= listing.difficulty === 'Easy' ? 'selected' : '' %>>Easy</option>
                                <option value="Moderate" <%= listing.difficulty === 'Moderate' ? 'selected' : '' %>>Moderate</option>
                                <option value="Challenging" <%= listing.difficulty === 'Challenging' ? 'selected' : '' %>>Challenging</option>
                            </select>
                        </div>
                        
                        <hr class="my-4">
                        
                        <!-- Buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary rounded-3 px-4 py-2">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary rounded-3 px-5 py-2">
                                <i class="fas fa-check-circle me-2"></i> Confirm Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ========== CONSTANTS ==========
    const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB per file
    const MAX_IMAGE_DIMENSION = 1920;
    
    // ========== CATEGORY SELECTION - UP TO 10 ==========
    const categoryInputs = document.querySelectorAll('.category-input');
    const categoryError = document.getElementById('category-error');
    const categoryCount = document.getElementById('category-count');
    const selectedCountSpan = document.getElementById('selected-count');
    
    function updateCategoryCount() {
        const checkedCount = document.querySelectorAll('.category-input:checked').length;
        selectedCountSpan.textContent = checkedCount;
        
        if (checkedCount >= 10) {
            categoryCount.style.color = '#dc3545';
            categoryInputs.forEach(input => {
                if (!input.checked) {
                    input.disabled = true;
                }
            });
        } else {
            categoryCount.style.color = '#6c757d';
            categoryInputs.forEach(input => {
                input.disabled = false;
            });
        }
    }
    
    categoryInputs.forEach(input => {
        input.addEventListener('change', function() {
            const checkedCount = document.querySelectorAll('.category-input:checked').length;
            
            if (checkedCount > 10) {
                this.checked = false;
                categoryError.style.display = 'block';
            } else {
                categoryError.style.display = 'none';
            }
            
            updateCategoryCount();
        });
    });
    
    // Initialize count
    updateCategoryCount();
    
    // ========== IMAGE COMPRESSION FUNCTION ==========
    async function compressImage(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = (event) => {
                const img = new Image();
                img.src = event.target.result;
                img.onload = () => {
                    let width = img.width;
                    let height = img.height;
                    
                    if (width > height) {
                        if (width > MAX_IMAGE_DIMENSION) {
                            height = Math.round(height * MAX_IMAGE_DIMENSION / width);
                            width = MAX_IMAGE_DIMENSION;
                        }
                    } else {
                        if (height > MAX_IMAGE_DIMENSION) {
                            width = Math.round(width * MAX_IMAGE_DIMENSION / height);
                            height = MAX_IMAGE_DIMENSION;
                        }
                    }
                    
                    const canvas = document.createElement('canvas');
                    canvas.width = width;
                    canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    
                    canvas.toBlob((blob) => {
                        const compressedFile = new File([blob], file.name, {
                            type: 'image/jpeg',
                            lastModified: Date.now()
                        });
                        resolve(compressedFile);
                    }, 'image/jpeg', 0.8);
                };
                img.onerror = reject;
            };
            reader.onerror = reject;
        });
    }
    
    // ========== IMAGE UPLOAD HANDLING ==========
    const imageUpload = document.getElementById('imageUpload');
    const uploadPreview = document.getElementById('uploadPreview');
    const imageCount = document.getElementById('imageCount');
    const uploadCount = document.getElementById('uploadCount');
    const fileSizeWarning = document.getElementById('fileSizeWarning');
    const compressionStatus = document.getElementById('compressionStatus');
    let selectedFiles = [];
    let isCompressing = false;
    
    if (imageUpload) {
        imageUpload.addEventListener('change', async function(e) {
            if (isCompressing) {
                alert('Please wait for current compression to finish');
                return;
            }
            
            const files = Array.from(e.target.files);
            
            if (files.length > 30) {
                alert('You can only upload up to 30 images');
                imageUpload.value = '';
                return;
            }
            
            const oversizedFiles = files.filter(file => file.size > MAX_FILE_SIZE);
            if (oversizedFiles.length > 0) {
                fileSizeWarning.style.display = 'block';
                fileSizeWarning.innerHTML = `<i class="fas fa-exclamation-triangle"></i> ${oversizedFiles.length} file(s) are too large. Compressing...`;
                
                compressionStatus.style.display = 'block';
                compressionStatus.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Compressing ${oversizedFiles.length} large image(s)...`;
                
                isCompressing = true;
                
                try {
                    const compressedFiles = await Promise.all(files.map(async file => {
                        if (file.size > MAX_FILE_SIZE) {
                            return await compressImage(file);
                        }
                        return file;
                    }));
                    
                    const dt = new DataTransfer();
                    compressedFiles.forEach(file => dt.items.add(file));
                    imageUpload.files = dt.files;
                    
                    selectedFiles = compressedFiles;
                    
                    compressionStatus.style.display = 'none';
                    fileSizeWarning.style.display = 'none';
                    
                    const successMsg = document.createElement('div');
                    successMsg.className = 'alert alert-success alert-dismissible fade show mt-2';
                    successMsg.innerHTML = `
                        <i class="fas fa-check-circle"></i> ${oversizedFiles.length} large image(s) compressed successfully!
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    `;
                    uploadPreview.parentNode.insertBefore(successMsg, uploadPreview);
                    
                    setTimeout(() => {
                        if (successMsg.parentNode) {
                            successMsg.remove();
                        }
                    }, 3000);
                    
                } catch (error) {
                    console.error('Compression error:', error);
                    alert('Error compressing images. Please try again with smaller files.');
                    selectedFiles = files;
                } finally {
                    isCompressing = false;
                }
            } else {
                fileSizeWarning.style.display = 'none';
                selectedFiles = files;
            }
            
            updateImageCount(selectedFiles.length);
            displayUploadPreviews(selectedFiles);
        });
    }
    
    function displayUploadPreviews(files) {
        if (!uploadPreview) return;
        
        uploadPreview.innerHTML = '';
        
        if (files.length === 0) {
            uploadCount.textContent = '';
            return;
        }
        
        files.forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const col = document.createElement('div');
                col.className = 'col-4 col-md-3 col-lg-2 mb-2';
                col.innerHTML = `
                    <div class="preview-image">
                        <img src="${e.target.result}" alt="Preview ${index + 1}">
                        <button type="button" class="remove-btn" onclick="removeUploadImage(${index})">
                            <i class="fas fa-times"></i>
                        </button>
                        <span class="badge bg-secondary position-absolute bottom-0 end-0 m-1 file-size-badge">${(file.size / 1024).toFixed(0)}KB</span>
                    </div>
                `;
                uploadPreview.appendChild(col);
            };
            reader.readAsDataURL(file);
        });
        
        uploadCount.textContent = `${files.length} image(s) selected (Total: ${(files.reduce((acc, f) => acc + f.size, 0) / (1024 * 1024)).toFixed(2)}MB)`;
    }
    
    window.updateImageCount = function(count) {
        if (!imageCount) return;
        imageCount.textContent = `${count} / 30 new images selected`;
        if (count === 0) {
            imageCount.className = 'badge bg-secondary';
        } else if (count > 0 && count < 30) {
            imageCount.className = 'badge bg-warning text-dark';
        } else {
            imageCount.className = 'badge bg-success';
        }
    };
    
    window.removeUploadImage = function(index) {
        selectedFiles.splice(index, 1);
        
        const dt = new DataTransfer();
        selectedFiles.forEach(file => dt.items.add(file));
        imageUpload.files = dt.files;
        
        displayUploadPreviews(selectedFiles);
        updateImageCount(selectedFiles.length);
    };
    
    // ========== FORM SUBMIT HANDLING - FIXED VERSION ==========
    const form = document.getElementById('editListingForm');
    
    if (form) {
        form.addEventListener('submit', function(e) {
            // Validate categories
            const checkedCategories = document.querySelectorAll('.category-input:checked').length;
            if (checkedCategories === 0) {
                e.preventDefault();
                alert('Please select at least 1 category');
                return false;
            }
            
            if (checkedCategories > 10) {
                e.preventDefault();
                alert('You can only select up to 10 categories');
                return false;
            }
            
            // Process amenities and experiences
            const amenities = document.getElementById('amenities');
            const experiences = document.getElementById('experiences');
            
            // Remove any existing hidden inputs first
            const existingAmenities = document.querySelectorAll('input[name^="listing[amenities]"]');
            const existingExperiences = document.querySelectorAll('input[name^="listing[experiences]"]');
            
            existingAmenities.forEach(el => el.remove());
            existingExperiences.forEach(el => el.remove());
            
            // Process amenities
            if (amenities && amenities.value && amenities.value.trim() !== '') {
                const items = amenities.value.split(',').map(item => item.trim()).filter(item => item !== '');
                
                items.forEach((item, index) => {
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `listing[amenities][${index}]`;
                    hidden.value = item;
                    form.appendChild(hidden);
                });
            }
            
            // Process experiences
            if (experiences && experiences.value && experiences.value.trim() !== '') {
                const items = experiences.value.split(',').map(item => item.trim()).filter(item => item !== '');
                
                items.forEach((item, index) => {
                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = `listing[experiences][${index}]`;
                    hidden.value = item;
                    form.appendChild(hidden);
                });
            }
            
            // Let the form submit normally
            return true;
        });
    }
});
</script>
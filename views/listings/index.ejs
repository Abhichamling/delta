<!-- Page Header with Filters -->
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-light">
            <% if (search) { %>
                <i class="fa-regular fa-magnifying-glass me-2" style="color: #000000;"></i> 
                Search: "<%= search %>"
            <% } else if (category && category !== 'All') { %>
                <span style="color: #000000;"><%= category %></span> 
            <% } else { %>
                All Experiences
            <% } %>
            <span class="fs-6 text-muted ms-2">(<%= typeof allListings !== 'undefined' ? allListings.length : 0 %> listings)</span>
        </h2>
        
        <!-- Difficulty Filter - Only for relevant categories -->
        <% if(category && ['Trekking', 'Adventure', 'Himalayan', 'Mountain', 'Camping'].includes(category)) { %>
            <div class="dropdown">
                <button class="btn btn-outline-secondary btn-sm rounded-pill dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fa-regular fa-chart-line me-1"></i> Difficulty
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item <%= !difficulty ? 'active' : '' %>" href="?category=<%= category %>">All</a></li>
                    <li><a class="dropdown-item <%= difficulty === 'Easy' ? 'active' : '' %>" href="?category=<%= category %>&difficulty=Easy">Easy</a></li>
                    <li><a class="dropdown-item <%= difficulty === 'Moderate' ? 'active' : '' %>" href="?category=<%= category %>&difficulty=Moderate">Moderate</a></li>
                    <li><a class="dropdown-item <%= difficulty === 'Challenging' ? 'active' : '' %>" href="?category=<%= category %>&difficulty=Challenging">Challenging</a></li>
                </ul>
            </div>
        <% } %>
    </div>

    <!-- Listings Grid -->
    <% if (typeof allListings !== 'undefined' && allListings.length === 0) { %>
        <div class="text-center py-5">
            <i class="fa-regular fa-face-frown" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3 fw-light">No experiences found</h3>
            <% if (currentUser) { %>
                <a href="/listings/new" class="btn btn-primary btn-lg mt-3 rounded-pill px-5" style="background-color: #000000;">
                    <i class="fa-regular fa-plus me-2"></i> Share Your Experience
                </a>
            <% } else { %>
                <a href="/login" class="btn btn-primary btn-lg mt-3 rounded-pill px-5" style="background-color: #000000;">
                    <i class="fa-regular fa-right-to-bracket me-2"></i> Login to Share
                </a>
            <% } %>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% allListings.forEach(listing => { %>
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 listing-card border-0">
                        <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                            <div class="position-relative">
                                <% 
                                    let imageUrl = 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=400';
                                    if (listing.images && listing.images.length > 0 && listing.images[0].url) {
                                        imageUrl = listing.images[0].url;
                                        if (!imageUrl.startsWith('http') && !imageUrl.startsWith('/uploads')) {
                                            imageUrl = '/uploads/' + imageUrl;
                                        }
                                    }
                                %>
                                <img src="<%= imageUrl %>" 
                                     class="card-img-top rounded-4" 
                                     alt="<%= listing.title %>" 
                                     style="height: 250px; object-fit: cover; aspect-ratio: 1/1;"
                                     onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=400';">
                                
                                <button class="btn position-absolute top-0 end-0 m-2 text-white like-btn" onclick="event.preventDefault()">
                                    <i class="fa-regular fa-heart fa-lg"></i>
                                </button>
                                <% if(listing.category) { %>
                                    <span class="position-absolute bottom-0 start-0 m-2 badge rounded-pill category-badge">
                                        <%= listing.category %>
                                    </span>
                                <% } %>
                            </div>
                            <div class="card-body px-0 pb-0">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="card-title fw-semibold mb-1"><%= listing.location %>, <%= listing.country %></h6>
                                        <p class="card-text text-muted small text-truncate" style="max-width: 200px;">
                                            <%= listing.title %>
                                        </p>
                                    </div>
                                    <span class="small"><i class="fa-regular fa-star text-warning me-1"></i> 4.8</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="fw-bold">₹<%= listing.price ? listing.price.toLocaleString('en-IN') : '0' %></span>
                                    <span class="text-muted small"><%= listing.duration || listing.bedrooms ? listing.bedrooms + (listing.bedrooms > 1 ? ' beds' : ' bed') : '1 night' %></span>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</div>

<%- include('../includes/footer') %>

<style>
/* Category filters styles */
.category-filters {
    position: sticky;
    top: 80px;
    z-index: 999;
    background-color: white;
    padding: 1.2rem 0;
    border-bottom: 1px solid #eaeaea;
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    white-space: nowrap;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin-bottom: 2rem;
}

.category-filters::-webkit-scrollbar {
    display: none;
}

.category-filters .d-flex {
    gap: 3.5rem;
    min-width: max-content;
}

.category-item {
    display: inline-block;
    padding: 8px 16px;
    background: transparent;
    border-radius: 30px;
    text-decoration: none;
    color: #666;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s;
}

.category-item i {
    margin-right: 8px;
}

.category-item:hover, .category-item.active {
    background-color: #000;
    color: white;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .category-filters {
        top: 65px;
        padding: 0.8rem 0;
    }
    
    .category-filters .d-flex {
        gap: 2rem;
    }
}

@media (max-width: 576px) {
    .category-filters .d-flex {
        gap: 2.5rem;
    }
}

.listing-card {
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
}

.listing-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
}

.category-badge {
    background-color: rgba(0,0,0,0.7);
    font-size: 0.75rem;
    padding: 5px 10px;
}

.rounded-4 {
    border-radius: 1rem !important;
}
</style>